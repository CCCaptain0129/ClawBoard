#!/usr/bin/env node
/**
 * progress-sync-cli - 将看板(JSON)进度回写到 04-进度跟踪.md
 * 
 * PMW-023 Phase 1 实现
 * 
 * 用法:
 *   ./progress-sync-cli <projectId> [docPath]
 * 
 * 示例:
 *   ./progress-sync-cli pm-workflow-automation
 *   ./progress-sync-cli pm-workflow-automation /path/to/04-进度跟踪.md
 */

const http = require('http');

const API_HOST = 'localhost';
const API_PORT = 3000;

function syncProgress(projectId, docPath) {
  const postData = JSON.stringify({ docPath });
  
  const options = {
    hostname: API_HOST,
    port: API_PORT,
    path: `/api/sync/progress-to-doc/${projectId}`,
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'Content-Length': Buffer.byteLength(postData)
    }
  };

  console.log(`\n🔄 Syncing progress for project: ${projectId}`);
  console.log(`   API: http://${API_HOST}:${API_PORT}/api/sync/progress-to-doc/${projectId}`);
  console.log('');

  const req = http.request(options, (res) => {
    let data = '';
    
    res.on('data', (chunk) => {
      data += chunk;
    });
    
    res.on('end', () => {
      try {
        const result = JSON.parse(data);
        
        if (result.success) {
          console.log('✅ Progress sync completed!\n');
          console.log(`   Project: ${result.projectId}`);
          console.log(`   Progress: ${result.progress.percentage}% (${result.progress.completed}/${result.progress.total} tasks)`);
          console.log(`   - Done: ${result.progress.completed}`);
          console.log(`   - In Progress: ${result.progress.inProgress}`);
          console.log(`   - Todo: ${result.progress.todo}`);
          console.log('');
          console.log(`   Updated sections:`);
          result.updatedSections.forEach(s => console.log(`     • ${s}`));
          console.log('');
          console.log(`   Message: ${result.message}`);
        } else {
          console.error('❌ Sync failed:', result.error);
          if (result.details) {
            console.error('   Details:', result.details);
          }
          process.exit(1);
        }
      } catch (e) {
        console.error('❌ Failed to parse response:', e.message);
        console.error('   Raw response:', data);
        process.exit(1);
      }
    });
  });

  req.on('error', (e) => {
    console.error('❌ Request failed:', e.message);
    console.error('');
    console.error('   Make sure the backend server is running:');
    console.error('   cd src/backend && npm run dev');
    process.exit(1);
  });

  req.write(postData);
  req.end();
}

// Main
const args = process.argv.slice(2);

if (args.length === 0 || args[0] === '-h' || args[0] === '--help') {
  console.log('');
  console.log('progress-sync-cli - 将看板(JSON)进度回写到 04-进度跟踪.md');
  console.log('');
  console.log('用法:');
  console.log('  ./progress-sync-cli <projectId> [docPath]');
  console.log('');
  console.log('参数:');
  console.log('  projectId  项目ID (如: pm-workflow-automation)');
  console.log('  docPath    可选的文档路径 (默认: 项目 docs 目录)');
  console.log('');
  console.log('示例:');
  console.log('  ./progress-sync-cli pm-workflow-automation');
  console.log('  ./progress-sync-cli openclaw-visualization');
  console.log('');
  console.log('API 端点:');
  console.log('  POST /api/sync/progress-to-doc/:projectId');
  console.log('');
  process.exit(0);
}

const projectId = args[0];
const docPath = args[1] || null;

syncProgress(projectId, docPath);