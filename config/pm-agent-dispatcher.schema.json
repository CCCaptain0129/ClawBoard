{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PM-Agent-Dispatcher 配置",
  "type": "object",
  "properties": {
    "projectAllowlist": {
      "type": "array",
      "items": { "type": "string" },
      "description": "允许调度的项目 ID 列表（空 = 所有项目）"
    },
    "pollIntervalMs": {
      "type": "integer",
      "minimum": 5000,
      "default": 30000,
      "description": "轮询间隔（毫秒）"
    },
    "maxConcurrent": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10,
      "default": 3,
      "description": "最大并发 subagent 数量"
    },
    "backendUrl": {
      "type": "string",
      "format": "uri",
      "default": "http://localhost:3000",
      "description": "后端 API 地址"
    },
    "tasksDir": {
      "type": "string",
      "default": "./tasks",
      "description": "任务数据目录"
    },
    "logsDir": {
      "type": "string",
      "default": "./tmp/logs",
      "description": "日志目录"
    },
    "promptLogFile": {
      "type": "string",
      "default": "./tmp/logs/pm-prompts.log",
      "description": "Prompt 日志文件"
    },
    "dispatchRecordFile": {
      "type": "string",
      "default": "./docs/internal/SUBAGENTS任务分发记录.md",
      "description": "分发记录文件"
    },
    "globalConstraints": {
      "type": "object",
      "properties": {
        "codeStyle": {
          "type": "string",
          "description": "代码风格要求"
        },
        "commitStyle": {
          "type": "string",
          "description": "提交信息格式"
        },
        "testRequired": {
          "type": "boolean",
          "default": false,
          "description": "是否要求测试"
        },
        "docRequired": {
          "type": "boolean",
          "default": true,
          "description": "是否要求文档更新"
        },
        "timeoutMinutes": {
          "type": "integer",
          "default": 30,
          "description": "任务超时时间（分钟）"
        },
        "defaultModel": {
          "type": "string",
          "default": "bailian/glm-4.7",
          "description": "默认使用的模型"
        }
      }
    }
  }
}