#!/bin/bash

set -e

PROJECT_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

print_help() {
  cat <<'EOF'
ClawBoard Unified CLI

Usage:
  ./clawboard <command> [args...]

Commands:
  install        Run install wizard
  start          Start services
  stop           Stop services
  restart        Restart services
  verify         Verify service health
  status         Alias of verify --quick
  token          Print BOARD_ACCESS_TOKEN from .env
  help           Show this help

Examples:
  ./clawboard install
  ./clawboard start
  ./clawboard start -- --foreground
  ./clawboard verify -- --full

Notes:
  - Everything after `--` is passed to the underlying script.
  - Underlying scripts are in scripts/cli/.
EOF
}

main() {
  if [ $# -eq 0 ]; then
    print_help
    exit 0
  fi

  local cmd="$1"
  shift

  case "$cmd" in
    help|-h|--help)
      print_help
      ;;
    install)
      "$PROJECT_ROOT/scripts/cli/install.sh" "$@"
      ;;
    start)
      "$PROJECT_ROOT/scripts/cli/start.sh" "$@"
      ;;
    stop)
      "$PROJECT_ROOT/scripts/cli/stop.sh" "$@"
      ;;
    restart)
      "$PROJECT_ROOT/scripts/cli/stop.sh"
      "$PROJECT_ROOT/scripts/cli/start.sh" "$@"
      ;;
    verify)
      "$PROJECT_ROOT/scripts/cli/verify.sh" "$@"
      ;;
    status)
      "$PROJECT_ROOT/scripts/cli/verify.sh" --quick "$@"
      ;;
    token)
      local env_file="$PROJECT_ROOT/.env"
      if [ ! -f "$env_file" ]; then
        echo "No .env file found at: $env_file" >&2
        echo "Run: ./clawboard install" >&2
        exit 1
      fi

      local token
      token=$(awk -F= '/^BOARD_ACCESS_TOKEN=/{print substr($0, index($0, "=")+1); exit}' "$env_file")
      if [ -z "$token" ]; then
        echo "BOARD_ACCESS_TOKEN not found in .env" >&2
        echo "Run: ./clawboard install" >&2
        exit 1
      fi

      echo "$token"
      ;;
    *)
      echo "Unknown command: $cmd" >&2
      echo ""
      print_help
      exit 1
      ;;
  esac
}

main "$@"
