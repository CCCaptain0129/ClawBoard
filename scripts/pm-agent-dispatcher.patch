/**
 * 示例 2：在 SubagentManager 中提取并发送 prompt
 */
async function onSubagentCompleteExample(taskId, subagentId, result) {
  // 1. 从日志中提取 prompt
  const prompt = extractPromptFromLog(taskId, subagentId);
  
  if (!prompt) {
    log(`未找到任务 ${taskId} 的 prompt，跳过通知`, 'WARN');
    return;
  }
  
  // 2. 查找任务和项目信息
  const task = await getTaskById(taskId);
  const project = await getProjectById(task.projectId);
  
  // 3. 生成通知消息
  const notification = generatePromptCompletionNotification(
    task,
    project,
    subagentId,
    prompt,
    result
  );
  
  if (notification.success) {
    // 4. 发送消息到飞书（待实现）
    log(`Prompt 完成通知已生成：${notification.message.length} 字符`);
    
    // TODO: 调用飞书 API 发送消息
    // await sendFeishuMessage(notification.message);
  }
}

