#!/bin/bash
# task-cli - 任务看板命令行工具
# 用法: ./task-cli <command> [options]

set -e

BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECTS_FILE="$BASE_DIR/tasks/projects.json"
API_BASE="http://localhost:3000/api/tasks"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 打印帮助信息
function show_help() {
  cat << EOF
任务看板命令行工具

用法: ./task-cli <command> [options]

命令:
  create-project   创建新项目
  create-task      创建新任务
  update           更新任务状态
  list             列出项目或任务
  sync             同步 Markdown
  progress         查看项目进度

创建项目:
  ./task-cli create-project \\
    --id my-project \\
    --name "项目名称" \\
    --description "项目描述" \\
    --color "#3B82F6" \\
    --icon "🎯"

创建任务:
  ./task-cli create-task \\
    --project openclaw-visualization \\
    --title "任务标题" \\
    --description "任务描述" \\
    --priority P1 \\
    --labels frontend,feature \\
    --assignee @username

更新任务:
  ./task-cli update TASK-001 --status done
  ./task-cli update TASK-001 --assignee @john

列出任务:
  ./task-cli list --project openclaw-visualization
  ./task-cli list --project openclaw-visualization --status todo

查看进度:
  ./task-cli progress --project openclaw-visualization

同步:
  ./task-cli sync --from-markdown openclaw-visualization
  ./task-cli sync --to-markdown openclaw-visualization

EOF
}

# 检查后端服务
function check_api() {
  if ! curl -s http://localhost:3000/health > /dev/null 2>&1; then
    echo -e "${RED}错误: 后端服务未运行${NC}"
    echo "请先启动后端服务: cd src/backend && npm run dev"
    exit 1
  fi
}

# 生成时间戳
function timestamp() {
  date -u +"%Y-%m-%dT%H:%M:%S.000Z"
}

# 创建项目
function create_project() {
  local id=""
  local name=""
  local description=""
  local color="#3B82F6"
  local icon="🎯"

  while [[ $# -gt 0 ]]; do
    case $1 in
      --id) id="$2"; shift 2 ;;
      --name) name="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --color) color="$2"; shift 2 ;;
      --icon) icon="$2"; shift 2 ;;
      *) echo -e "${RED}未知选项: $1${NC}"; exit 1 ;;
    esac
  done

  if [[ -z "$id" || -z "$name" ]]; then
    echo -e "${RED}错误: --id 和 --name 是必填项${NC}"
    exit 1
  fi

  # 读取现有项目
  local projects=$(cat "$PROJECTS_FILE")
  local new_project=$(cat << EOF
{
  "id": "$id",
  "name": "$name",
  "description": "$description",
  "status": "active",
  "leadAgent": null,
  "color": "$color",
  "icon": "$icon",
  "createdAt": "$(timestamp)",
  "updatedAt": "$(timestamp)"
}
EOF
)

  # 添加到项目列表
  local updated=$(echo "$projects" | jq ". + [$new_project]")
  echo "$updated" | jq '.' > "$PROJECTS_FILE"

  # 创建任务文件
  cat > "$BASE_DIR/tasks/$id-tasks.json" << EOF
{
  "id": "$id",
  "name": "$name",
  "description": "$description",
  "status": "active",
  "color": "$color",
  "icon": "$icon",
  "createdAt": "$(timestamp)",
  "updatedAt": "$(timestamp)",
  "tasks": []
}
EOF

  echo -e "${GREEN}✅ 项目创建成功: $name${NC}"
  echo "   项目 ID: $id"
  echo "   任务文件: tasks/$id-tasks.json"
}

# 创建任务
function create_task() {
  check_api

  local project=""
  local title=""
  local description=""
  local priority="P2"
  local labels=""
  local assignee=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --project) project="$2"; shift 2 ;;
      --title) title="$2"; shift 2 ;;
      --description) description="$2"; shift 2 ;;
      --priority) priority="$2"; shift 2 ;;
      --labels) labels="$2"; shift 2 ;;
      --assignee) assignee="$2"; shift 2 ;;
      *) echo -e "${RED}未知选项: $1${NC}"; exit 1 ;;
    esac
  done

  if [[ -z "$project" || -z "$title" ]]; then
    echo -e "${RED}错误: --project 和 --title 是必填项${NC}"
    exit 1
  fi

  # 生成任务 ID
  local task_file="$BASE_DIR/tasks/$project-tasks.json"
  local existing_tasks=$(jq '.tasks | length' "$task_file")
  local task_num=$((existing_tasks + 1))
  local task_id=$(printf "TASK-%03d" $task_num)

  # 转换标签为数组
  local labels_array="[]"
  if [[ -n "$labels" ]]; then
    labels_array=$(echo "$labels" | jq -R 'split(",")')
  fi

  # 创建任务对象
  local new_task=$(cat << EOF
{
  "id": "$task_id",
  "title": "$title",
  "description": "$description",
  "status": "todo",
  "priority": "$priority",
  "labels": $labels_array,
  "assignee": ${assignee:+\"$assignee\"},
  "claimedBy": null,
  "dueDate": null,
  "createdAt": "$(timestamp)",
  "updatedAt": "$(timestamp)",
  "comments": []
}
EOF
)

  # 添加到任务文件
  local updated=$(jq ".tasks += [$new_task] | .updatedAt = \"$(timestamp)\"" "$task_file")
  echo "$updated" > "$task_file"

  echo -e "${GREEN}✅ 任务创建成功${NC}"
  echo "   任务 ID: $task_id"
  echo "   标题: $title"
  echo "   优先级: $priority"
}

# 更新任务
function update_task() {
  check_api

  local task_id=""
  local status=""
  local assignee=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --status) status="$2"; shift 2 ;;
      --assignee) assignee="$2"; shift 2 ;;
      *) task_id="$1"; shift ;;
    esac
  done

  if [[ -z "$task_id" ]]; then
    echo -e "${RED}错误: 请指定任务 ID${NC}"
    exit 1
  fi

  # 查找任务所属项目
  local project_id=""
  for task_file in "$BASE_DIR/tasks"/*-tasks.json; do
    if jq -e ".tasks[] | select(.id == \"$task_id\")" "$task_file" > /dev/null 2>&1; then
      project_id=$(basename "$task_file" "-tasks.json")
      break
    fi
  done

  if [[ -z "$project_id" ]]; then
    echo -e "${RED}错误: 找不到任务 $task_id${NC}"
    exit 1
  fi

  # 构建更新数据
  local update_data="{}"
  if [[ -n "$status" ]]; then
    update_data=$(echo "$update_data" | jq ". + {\"status\": \"$status\"}")
  fi
  if [[ -n "$assignee" ]]; then
    update_data=$(echo "$update_data" | jq ". + {\"assignee\": \"$assignee\"}")
  fi

  # 调用 API 更新
  local response=$(curl -s -X PUT \
    "$API_BASE/projects/$project_id/tasks/$task_id" \
    -H "Content-Type: application/json" \
    -d "$update_data")

  if [[ $? -eq 0 ]]; then
    echo -e "${GREEN}✅ 任务更新成功${NC}"
    echo "   任务 ID: $task_id"
    echo "$response" | jq -r 'if .status then "   状态: \(.status)" end'
    echo "$response" | jq -r 'if .assignee then "   负责人: \(.assignee)" end'
  else
    echo -e "${RED}❌ 任务更新失败${NC}"
    exit 1
  fi
}

# 列出项目或任务
function list_items() {
  check_api

  local project=""
  local status=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --project) project="$2"; shift 2 ;;
      --status) status="$2"; shift 2 ;;
      *) echo -e "${RED}未知选项: $1${NC}"; exit 1 ;;
    esac
  done

  if [[ -n "$project" ]]; then
    # 列出项目任务
    local tasks=$(curl -s "$API_BASE/projects/$project/tasks")
    if [[ -n "$status" ]]; then
      tasks=$(echo "$tasks" | jq "[.[] | select(.status == \"$status\")]")
    fi
    
    echo -e "${BLUE}项目: $project${NC}"
    echo "$tasks" | jq -r '.[] | "  \(.id) \(.priority) \(.status) - \(.title)"'
  else
    # 列出所有项目
    local projects=$(curl -s "$API_BASE/projects")
    echo -e "${BLUE}所有项目:${NC}"
    echo "$projects" | jq -r '.[] | "  \(.id) \(.icon) \(.name) (\(.status))"'
  fi
}

# 查看进度
function show_progress() {
  check_api

  local project=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --project) project="$2"; shift 2 ;;
      *) echo -e "${RED}未知选项: $1${NC}"; exit 1 ;;
    esac
  done

  if [[ -n "$project" ]]; then
    # 查看单个项目进度
    local tasks=$(curl -s "$API_BASE/projects/$project/tasks")
    local total=$(echo "$tasks" | jq 'length')
    local todo=$(echo "$tasks" | jq '[.[] | select(.status == "todo")] | length')
    local in_progress=$(echo "$tasks" | jq '[.[] | select(.status == "in-progress")] | length')
    local done=$(echo "$tasks" | jq '[.[] | select(.status == "done")] | length')
    local progress=$(( done * 100 / total ))

    echo -e "${BLUE}项目进度: $project${NC}"
    echo "  总任务: $total"
    echo "  待处理: $todo"
    echo "  进行中: $in_progress"
    echo "  已完成: $done"
    echo -e "  进度: ${GREEN}$progress%${NC}"
    
    # 进度条
    local filled=$(( progress / 2 ))
    local empty=$(( 50 - filled ))
    printf "  ["
    printf "${GREEN}%${filled}s${NC}" | tr ' ' '='
    printf "%${empty}s" | tr ' ' ' '
    printf "]\n"
  else
    # 查看所有项目进度
    local projects=$(curl -s "$API_BASE/projects")
    echo -e "${BLUE}所有项目进度:${NC}"
    echo "$projects" | jq -r '.[].id' | while read -r project; do
      echo "---"
      $0 progress --project "$project"
    done
  fi
}

# 同步
function sync() {
  check_api

  local project=""
  local direction=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --from-markdown)
        direction="from"
        project="$2"
        shift 2
        ;;
      --to-markdown)
        direction="to"
        project="$2"
        shift 2
        ;;
      *) echo -e "${RED}未知选项: $1${NC}"; exit 1 ;;
    esac
  done

  if [[ -z "$project" ]]; then
    echo -e "${RED}错误: 请指定项目 ID${NC}"
    exit 1
  fi

  local endpoint="sync"
  if [[ "$direction" == "from" ]]; then
    endpoint="sync/from-markdown"
  elif [[ "$direction" == "to" ]]; then
    endpoint="sync/to-markdown"
  else
    endpoint="sync"
  fi

  local response=$(curl -s -X POST "$API_BASE/$endpoint/$project")
  echo "$response" | jq '.'

  if [[ "$(echo "$response" | jq -r '.success')" == "true" ]]; then
    echo -e "${GREEN}✅ 同步成功${NC}"
  else
    echo -e "${RED}❌ 同步失败${NC}"
    exit 1
  fi
}

# 主函数
function main() {
  if [[ $# -eq 0 ]]; then
    show_help
    exit 0
  fi

  local command="$1"
  shift

  case $command in
    create-project) create_project "$@" ;;
    create-task) create_task "$@" ;;
    update) update_task "$@" ;;
    list) list_items "$@" ;;
    progress) show_progress "$@" ;;
    sync) sync "$@" ;;
    help|--help|-h) show_help ;;
    *)
      echo -e "${RED}错误: 未知命令 '$command'${NC}"
      echo ""
      show_help
      exit 1
      ;;
  esac
}

# 运行主函数
main "$@"