# OpenClaw Visualization 监控脚本配置文件
# 复制此文件到 tmp/watch.conf 并根据需要修改

# 检查间隔（秒）
# 监控脚本检查服务状态的时间间隔
# 建议：开发环境 10-30 秒，生产环境 30-60 秒
CHECK_INTERVAL=30

# 最大重启次数（0 表示无限制）
# 在指定的时间窗口内允许的最大重启次数
# 防止服务无限重启循环
MAX_RESTART_COUNT=10

# 重启计数窗口（秒）
# 统计重启次数的时间窗口
# 默认 3600 秒（1小时）
RESTART_WINDOW=3600

# 健康检查超时（秒）
# HTTP 健康检查请求的超时时间
# 建议：5-10 秒
HEALTH_CHECK_TIMEOUT=5